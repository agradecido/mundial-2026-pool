generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth.js required tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  role             Role      @default(JUGADOR)
  fechaRegistro    DateTime  @default(now())
  ultimoAcceso     DateTime?
  hasChosenNickname Boolean  @default(false)
  welcomeModalViews Int      @default(0)

  accounts          Account[]
  sessions          Session[]
  pronosticos       Pronostico[]
  prediccionFutura  PrediccionFutura?
  bracketPicks      PronosticoBracket?
  modalDismissals   ModalDismissal[]
}

enum Role {
  ADMIN
  JUGADOR
}

model Partido {
  id                 String        @id @default(cuid())
  equipoLocal        String
  equipoVisitante    String
  fechaPartido       DateTime
  fase               Fase
  grupo              String?
  golesLocalReal     Int?
  golesVisitanteReal Int?
  estado             EstadoPartido @default(PROGRAMADO)

  pronosticos Pronostico[]
}

enum Fase {
  GRUPOS
  DIECISEISAVOS
  OCTAVOS
  CUARTOS
  SEMIFINAL
  TERCER_PUESTO
  FINAL
}

enum EstadoPartido {
  PROGRAMADO
  EN_PROGRESO
  FINALIZADO
}

model Pronostico {
  id             String   @id @default(cuid())
  userId         String
  partidoId      String
  golesLocal     Int
  golesVisitante Int
  puntosGanados  Int      @default(0)
  fechaGuardado  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)

  @@unique([userId, partidoId])
}

// Bracket prediction game — locked at tournament start
// picks JSON: { grupos: {A:[t1,t2],...}, terceros:[t,...×8],
//               octavos:[×16], cuartos:[×8], semifinal:[×4],
//               final:[×2], campeon:string }
model PronosticoBracket {
  id        String   @id @default(cuid())
  userId    String   @unique
  picks     Json     @default("{}")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrediccionFutura {
  id                   String  @id @default(cuid())
  userId               String  @unique
  campeonPronostico    String?
  subcampeonPronostico String?
  botaOroPronostico    String?
  puntosCampeon        Int     @default(0)
  puntosSubcampeon     Int     @default(0)
  puntosBota           Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Modal {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  emoji     String   @default("📢")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  dismissals ModalDismissal[]
}

model ModalDismissal {
  userId    String
  modalId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  modal Modal @relation(fields: [modalId], references: [id], onDelete: Cascade)

  @@id([userId, modalId])
}
