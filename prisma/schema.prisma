generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- NextAuth.js required tables ---

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// --- App models ---

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role      @default(JUGADOR)
  suspendido       Boolean   @default(false)
  fechaRegistro    DateTime  @default(now())
  ultimoAcceso     DateTime?
  ultimoAccesoQuiniela DateTime?
  hasChosenNickname Boolean  @default(false)
  welcomeModalViews Int      @default(0)

  accounts          Account[]
  sessions          Session[]
  pronosticos       Pronostico[]
  prediccionFutura  PrediccionFutura?
  bracketPicks      PronosticoBracket?
  modalDismissals   ModalDismissal[]
  gruposCreados     Grupo[]          @relation("GruposCreados")
  grupos            GrupoMiembro[]
  badge             BadgeUsuario?
}

enum Role {
  ADMIN
  EDITOR
  JUGADOR
}

model Partido {
  id                 String        @id @default(cuid())
  equipoLocal        String
  equipoVisitante    String
  fechaPartido       DateTime
  fase               Fase
  grupo              String?
  estadio            String?
  ciudad             String?
  golesLocalReal     Int?
  golesVisitanteReal Int?
  ganadorPenales     String?
  estado             EstadoPartido @default(PROGRAMADO)

  pronosticos Pronostico[]
  analisis    AnalisisPartido?
  prediccion  PrediccionPartido?
}

enum Fase {
  GRUPOS
  DIECISEISAVOS
  OCTAVOS
  CUARTOS
  SEMIFINAL
  TERCER_PUESTO
  FINAL
}

enum EstadoPartido {
  PROGRAMADO
  EN_PROGRESO
  FINALIZADO
}

model Pronostico {
  id             String   @id @default(cuid())
  userId         String
  partidoId      String
  golesLocal     Int
  golesVisitante Int
  puntosGanados  Int      @default(0)
  fechaGuardado  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)

  @@unique([userId, partidoId])
}

// Bracket prediction game — locked at tournament start
// picks JSON: { grupos: {A:[t1,t2],...}, terceros:[t,...×8],
//               octavos:[×16], cuartos:[×8], semifinal:[×4],
//               final:[×2], campeon:string }
model PronosticoBracket {
  id        String   @id @default(cuid())
  userId    String   @unique
  picks     Json     @default("{}")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrediccionFutura {
  id                   String  @id @default(cuid())
  userId               String  @unique
  campeonPronostico    String?
  subcampeonPronostico String?
  botaOroPronostico    String?
  puntosCampeon        Int     @default(0)
  puntosSubcampeon     Int     @default(0)
  puntosBota           Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Modal {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  body      String
  emoji     String   @default("📢")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  dismissals ModalDismissal[]
}

model ModalDismissal {
  userId    String
  modalId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)
  modal Modal @relation(fields: [modalId], references: [id], onDelete: Cascade)

  @@id([userId, modalId])
}

model Grupo {
  id        String   @id @default(cuid())
  nombre    String
  codigo    String   @unique
  creadorId String
  createdAt DateTime @default(now())

  creador  User           @relation("GruposCreados", fields: [creadorId], references: [id], onDelete: Cascade)
  miembros GrupoMiembro[]
}

model GrupoMiembro {
  grupoId  String
  userId   String
  joinedAt DateTime @default(now())

  grupo Grupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId],  references: [id], onDelete: Cascade)

  @@id([grupoId, userId])
}

model OddsCache {
  key       String   @id  // e.g. "mundial_h2h" | "mundial_outrights"
  data      Json
  updatedAt DateTime @updatedAt
}

enum PosicionJugador {
  GK
  DF
  MF
  FW
}

model Jugador {
  id          String          @id @default(cuid())
  nombre      String
  seleccion   String
  dorsal      Int
  posicion    PosicionJugador
  edad        Int?
  partidosInt Int             @default(0)
  goles       Int             @default(0)
  clubActual  String?

  // FIFA EA Sports 2025 stats
  fifaOvr     Int?
  fifaPac     Int?
  fifaSho     Int?
  fifaPas     Int?
  fifaDri     Int?
  fifaDef     Int?
  fifaPhy     Int?
  fifaPos     String?         // FIFA position (ST, CAM, CB, GK…)

  @@index([seleccion])
  @@unique([seleccion, dorsal])
}

model AnalisisPartido {
  id         String   @id @default(cuid())
  partidoId  String   @unique
  texto      String
  generadoEn DateTime @default(now())

  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
}

model PrediccionPartido {
  id          String   @id @default(cuid())
  partidoId   String   @unique
  homePercent Int
  drawPercent Int
  awayPercent Int
  marcador    String
  generadoEn  DateTime @default(now())

  partido Partido @relation(fields: [partidoId], references: [id], onDelete: Cascade)
}

model BadgeUsuario {
  id          String   @id @default(cuid())
  userId      String   @unique
  titulo      String
  emoji       String
  descripcion String
  generadoEn  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PartidoHistorico {
  id      String   @id @default(uuid())
  torneo  String
  fase    String
  fecha   DateTime
  equipo1 String
  equipo2 String
  goles1  Int
  goles2  Int

  @@index([equipo1, equipo2])
}

// Fila única (singleton) con ajustes globales editables desde /admin/ajustes.
model Configuracion {
  id                      String  @id @default("global")
  mostrarPronosticosAntes Boolean @default(false)
}
